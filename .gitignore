# Dependencies
node_modules/

# Build output
dist/

# Benchmark results (generated, often large)
bench/results/*
bench/ITERATIONS.md
!bench/results/.gitkeep

# Published benchmark results (tracked, but not workspace clones or MCP configs with tokens)
!bench/published-results/
bench/published-results/**/workspace/
bench/published-results/**/.mcp-config.json
bench/results/**/workspace/

# Blog draft (not version-controlled)
docs/blog.md

# Desloppify
.desloppify/
*.png

# OS
.DS_Store
